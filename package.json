{
  "name": "swiftcart-automation",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test automation framework for Swiftcart e-commerce site",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "test:smoke": "playwright test tests/login.spec.ts tests/products.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
